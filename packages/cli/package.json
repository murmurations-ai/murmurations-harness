{
  "name": "@murmuration/cli",
  "version": "0.0.0",
  "description": "Command-line interface for the Murmuration Harness daemon — start, stop, status.",
  "license": "MIT",
  "author": "Emergent Praxis murmuration",
  "homepage": "https://github.com/murmurations-ai/murmurations-harness/tree/main/packages/cli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/murmurations-ai/murmurations-harness.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/murmurations-ai/murmurations-harness/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "murmuration": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --build",
    "clean": "rm -rf dist .tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "start": "node dist/bin.js start",
    "test": "echo 'tests not yet configured (pending Engineering Circle test framework ADR)'"
  },
  "dependencies": {
    "@murmuration/core": "workspace:*"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
