{
  "name": "@murmurations-ai/cli",
  "version": "0.3.5",
  "description": "Command-line interface for the Murmuration Harness daemon — start, stop, status.",
  "license": "MIT",
  "author": "Emergent Praxis murmuration",
  "homepage": "https://github.com/murmurations-ai/murmurations-harness/tree/main/packages/cli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/murmurations-ai/murmurations-harness.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/murmurations-ai/murmurations-harness/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "murmuration": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "clean": "rm -rf dist .tsbuildinfo .tsbuildinfo.build",
    "typecheck": "tsc --noEmit",
    "start": "node dist/bin.js start"
  },
  "dependencies": {
    "@murmurations-ai/core": "workspace:*",
    "@murmurations-ai/github": "workspace:*",
    "@murmurations-ai/llm": "workspace:*",
    "@murmurations-ai/secrets-dotenv": "workspace:*",
    "@murmurations-ai/signals": "workspace:*",
    "yaml": "^2.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
