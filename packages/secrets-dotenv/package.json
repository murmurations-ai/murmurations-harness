{
  "name": "@murmurations-ai/secrets-dotenv",
  "version": "0.6.2",
  "description": "Default SecretsProvider for the Murmuration Harness — reads from a .env file at the murmuration root.",
  "license": "MIT",
  "author": "Murmuration Harness Contributors",
  "homepage": "https://github.com/murmurations-ai/murmurations-harness/tree/main/packages/secrets-dotenv",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/murmurations-ai/murmurations-harness.git",
    "directory": "packages/secrets-dotenv"
  },
  "bugs": {
    "url": "https://github.com/murmurations-ai/murmurations-harness/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "clean": "rm -rf dist .tsbuildinfo .tsbuildinfo.build",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@murmurations-ai/core": "workspace:*",
    "dotenv": "^16.4.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
