{
  "name": "@murmurations-ai/core",
  "version": "0.4.1",
  "description": "Core runtime for the Murmuration Harness — scheduler, signal aggregator, plugin registry, and executor interface.",
  "license": "MIT",
  "author": "Emergent Praxis murmuration",
  "homepage": "https://github.com/murmurations-ai/murmurations-harness/tree/main/packages/core",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/murmurations-ai/murmurations-harness.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/murmurations-ai/murmurations-harness/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./execution": {
      "types": "./dist/execution/index.d.ts",
      "import": "./dist/execution/index.js"
    },
    "./execution/subprocess": {
      "types": "./dist/execution/subprocess.d.ts",
      "import": "./dist/execution/subprocess.js"
    },
    "./governance": {
      "types": "./dist/governance/index.d.ts",
      "import": "./dist/governance/index.js"
    },
    "./scheduler": {
      "types": "./dist/scheduler/index.d.ts",
      "import": "./dist/scheduler/index.js"
    },
    "./signals": {
      "types": "./dist/signals/index.d.ts",
      "import": "./dist/signals/index.js"
    },
    "./daemon": {
      "types": "./dist/daemon/index.d.ts",
      "import": "./dist/daemon/index.js"
    },
    "./identity": {
      "types": "./dist/identity/index.d.ts",
      "import": "./dist/identity/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --build tsconfig.build.json && cp src/daemon/dashboard.html dist/daemon/dashboard.html",
    "clean": "rm -rf dist .tsbuildinfo .tsbuildinfo.build",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "cron-parser": "^4.9.0",
    "gray-matter": "^4.0.3",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}
