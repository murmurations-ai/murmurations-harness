{
  "name": "@murmurations-ai/signals",
  "version": "0.3.6",
  "description": "Default SignalAggregator for the Murmuration Harness — github + filesystem sources with interim trust taxonomy.",
  "license": "MIT",
  "author": "Emergent Praxis murmuration",
  "homepage": "https://github.com/murmurations-ai/murmurations-harness/tree/main/packages/signals",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/murmurations-ai/murmurations-harness.git",
    "directory": "packages/signals"
  },
  "bugs": {
    "url": "https://github.com/murmurations-ai/murmurations-harness/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
