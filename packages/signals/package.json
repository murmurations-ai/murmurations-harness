    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "clean": "rm -rf dist .tsbuildinfo .tsbuildinfo.build",
    "typecheck": "tsc --noEmit"
