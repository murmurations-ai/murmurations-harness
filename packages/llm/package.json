{
  "name": "@murmurations-ai/llm",
  "version": "0.2.3",
  "description": "Typed LLM client for the Murmuration Harness — four-provider, SecretValue auth, per-call cost hook.",
  "license": "MIT",
  "author": "Emergent Praxis murmuration",
  "homepage": "https://github.com/murmurations-ai/murmurations-harness/tree/main/packages/llm",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/murmurations-ai/murmurations-harness.git",
    "directory": "packages/llm"
  },
  "bugs": {
    "url": "https://github.com/murmurations-ai/murmurations-harness/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./pricing": {
      "types": "./dist/pricing/index.d.ts",
      "import": "./dist/pricing/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "clean": "rm -rf dist .tsbuildinfo .tsbuildinfo.build",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@murmurations-ai/core": "workspace:*",
    "zod": "^4.3.6"
  }
}
